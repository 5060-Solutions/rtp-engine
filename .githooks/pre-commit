#!/bin/sh
# Pre-commit hook: run cargo fmt and clippy checks

set -e

echo "Running cargo fmt check..."
cargo fmt --all -- --check
if [ $? -ne 0 ]; then
    echo "ERROR: cargo fmt check failed. Run 'cargo fmt --all' to fix."
    exit 1
fi

echo "Running cargo clippy..."
cargo clippy --all-features --all-targets 2>&1
if [ $? -ne 0 ]; then
    echo "ERROR: cargo clippy failed. Fix the warnings above."
    exit 1
fi

echo "Pre-commit checks passed."
